# ---------------------------------------------------------------------------
# Google Cloud
# ---------------------------------------------------------------------------
# Your Google Cloud Project ID (required for Vertex AI and Secret Manager)
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI location for Gemini API calls (defaults to 'global' if unset).
# IMPORTANT: gemini-3-flash-preview and gemini-3.1-flash-lite-preview are
# only available via the global endpoint. Use 'global' for these models.
# Regional endpoints (us-central1, europe-west4, etc.) are for older
# Gemini 2.x models only.
GOOGLE_CLOUD_LOCATION=global

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------
# Model to use (defaults to 'gemini-2.5-flash' if unset)
# MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Agent Configuration
# ---------------------------------------------------------------------------
# URL of the agent (defaults to http://127.0.0.1:8000 if unset)
# AGENT_URL=http://127.0.0.1:8000

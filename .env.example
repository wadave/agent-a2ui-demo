# ---------------------------------------------------------------------------
# Google Cloud
# ---------------------------------------------------------------------------
# Your Google Cloud Project ID (required for Vertex AI and Secret Manager)
GOOGLE_CLOUD_PROJECT=your-project-id

# Google Cloud Location/Region (defaults to 'global' if unset)
# Standard regions for Gemini on Vertex: us-central1, europe-west4, etc.
GOOGLE_CLOUD_LOCATION=us-central1

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------
# Model to use (defaults to 'gemini-2.5-flash' if unset)
# MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Agent Configuration
# ---------------------------------------------------------------------------
# URL of the agent (defaults to http://127.0.0.1:8000 if unset)
# AGENT_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Google Maps
# ---------------------------------------------------------------------------
# Google Maps API key (optional, for embedding maps in UI)
# If set, overrides Secret Manager lookup.
# GOOGLE_MAPS_API_KEY=your-maps-api-key

# Secret name in Secret Manager for the Maps API key (defaults to 'google_map_api_key')
# GOOGLE_MAPS_SECRET_NAME=google_map_api_key

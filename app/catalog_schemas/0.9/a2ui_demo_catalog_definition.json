{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "catalogId": "https://github.com/user/agent-a2ui-demo/a2ui_demo_catalog_definition.json",
  "components": {
    "Canvas": {
      "type": "object",
      "description": "Renders the UI element in a stateful panel. v0.9 root container for charts.",
      "allOf": [
        {
          "$ref": "common_types.json#/$defs/ComponentCommon"
        },
        {
          "type": "object",
          "properties": {
            "component": {
              "const": "Canvas"
            },
            "children": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Child component IDs."
            }
          },
          "required": [
            "component",
            "children"
          ]
        }
      ],
      "unevaluatedProperties": false
    },
    "VegaChart": {
      "type": "object",
      "description": "A Vega chart component implemented with Lit. Accepts a Vega-Lite spec.",
      "additionalProperties": false,
      "properties": {
        "spec": {
          "type": "object",
          "description": "The Vega/Vega-Lite specification."
        },
        "height": {
          "type": "number",
          "description": "The height of the chart in pixels."
        }
      },
      "required": [
        "spec"
      ]
    },
    "DataGrid": {
      "type": "object",
      "description": "Tabular data grid with sortable columns, type-aware formatting (currency, percentage, integer, number, date), and conditional cell coloring (negative numbers red, image URLs render inline). Use for status / detail tables in dashboards.",
      "additionalProperties": false,
      "properties": {
        "rowData": {
          "type": "array",
          "description": "Array of row objects. Each object's keys must match the `name` of a column in `schema.fields`.",
          "items": {
            "type": "object"
          }
        },
        "schema": {
          "type": "object",
          "description": "Column definitions. Drives display name, type-aware formatting and sort order.",
          "additionalProperties": false,
          "properties": {
            "fields": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "The data key in each rowData object."
                  },
                  "displayName": {
                    "type": "string",
                    "description": "Human-readable column header. Defaults to `name`."
                  },
                  "type": {
                    "type": "string",
                    "description": "Type hint that drives formatting and conditional coloring.",
                    "enum": [
                      "string",
                      "integer",
                      "number",
                      "currency",
                      "percentage",
                      "date",
                      "timestamp",
                      "datetime",
                      "image"
                    ]
                  },
                  "valueFormat": {
                    "type": "string",
                    "description": "Optional Excel-style format string (e.g. \"$#,##0.0,,\\\"M\\\"\", \"0.0%\", \"yyyy-mm-dd\")."
                  },
                  "category": {
                    "type": "string",
                    "description": "Optional grouping label."
                  },
                  "format": {
                    "type": "string",
                    "description": "Free-form formatting hint."
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          },
          "required": [
            "fields"
          ]
        },
        "maxHeight": {
          "type": "number",
          "description": "Maximum grid height in pixels before vertical scrolling kicks in. Defaults to 296."
        }
      },
      "required": [
        "rowData",
        "schema"
      ]
    }
  }
}

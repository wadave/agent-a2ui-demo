{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "catalogId": "https://github.com/user/agent-a2ui-demo/restaurant_finder_catalog_definition.json",
  "components": {
    "WebFrameUrl": {
      "type": "object",
      "description": "Embeds a web page in an iframe. Use for Google Maps embeds and other web content.",
      "allOf": [
        { "$ref": "common_types.json#/$defs/ComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "WebFrameUrl" },
            "url": {
              "$ref": "common_types.json#/$defs/DynamicString",
              "description": "The URL of the web page to embed."
            }
          },
          "required": ["component", "url"]
        }
      ],
      "unevaluatedProperties": false
    },
    "GoogleMap": {
      "type": "object",
      "description": "Displays a Google Map with optional pins.",
      "allOf": [
        { "$ref": "common_types.json#/$defs/ComponentCommon" },
        {
          "type": "object",
          "properties": {
            "component": { "const": "GoogleMap" },
            "center": {
              "description": "The center point of the map. Either a literal { lat, lng } object or a data binding.",
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "lat": { "type": "number" },
                    "lng": { "type": "number" }
                  },
                  "required": ["lat", "lng"],
                  "additionalProperties": false
                },
                { "$ref": "common_types.json#/$defs/DataBinding" }
              ]
            },
            "zoom": {
              "$ref": "common_types.json#/$defs/DynamicNumber",
              "description": "The zoom level of the map (1-20)."
            },
            "pins": {
              "description": "A list of pin objects to display on the map.",
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "lat": { "type": "number" },
                      "lng": { "type": "number" },
                      "name": { "type": "string" },
                      "description": { "type": "string" },
                      "background": { "type": "string" },
                      "borderColor": { "type": "string" },
                      "glyphColor": { "type": "string" }
                    },
                    "required": ["lat", "lng", "name"]
                  }
                },
                { "$ref": "common_types.json#/$defs/DataBinding" }
              ]
            }
          },
          "required": ["component", "center", "zoom"]
        }
      ],
      "unevaluatedProperties": false
    }
  }
}

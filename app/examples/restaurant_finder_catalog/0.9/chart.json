    }
  },
  {
    "version": "v0.9",
    "updateComponents": {
      "surfaceId": "sheet-chart",
      "components": [
        {
          "id": "root",
          "component": "Canvas",
          "children": ["chart-container"]
        },
        {
          "id": "chart-container",
          "component": "Column",
          "align": "center",
          "children": ["chart-header", "main-chart"]
        },
        {
          "id": "chart-header",
          "component": "Text",
          "variant": "h2",
          "text": { "path": "/chart/title" }
